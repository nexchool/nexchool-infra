# Copy to .env.prod (gitignored) in your EC2 home directory:
#   cp env/.env.prod.example .env.prod   (then fill in real values)
#
# On EC2 this file lives at ~/. env.prod — referenced by docker-compose.prod.yml

# ================== ECR IMAGE URLS ==================
# Replace 123456789012 with your AWS account ID
ECR_API_URL=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nexchool-server
ECR_ADMIN_WEB_URL=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nexchool-school-admin-panel
ECR_PANEL_URL=123456789012.dkr.ecr.ap-south-1.amazonaws.com/nexchool-super-admin-panel

# ================== DATABASE (RDS) ==================
DATABASE_URL=postgresql://postgres:CHANGEME@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/school_erp

# ================== REDIS / CELERY ==================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ================== FLASK API ==================
FLASK_APP=app:create_app
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_EXP_MINUTES=30
DEFAULT_USER_ROLE=Student
DEFAULT_TENANT_SUBDOMAIN=default

PORT=5001
GUNICORN_BIND=0.0.0.0:5001
WEB_CONCURRENCY=1
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

# ================== URLS / CORS ==================
BACKEND_URL=https://api.nexchool.in
FRONTEND_URL=schoolerp://
CORS_ORIGINS=https://app.nexchool.in,https://panel.nexchool.in
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None

# ================== EMAIL ==================
SMTP_SERVER=
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
DEFAULT_SENDER_NAME=
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# ================== CLOUDINARY ==================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ================== AWS ==================
AWS_REGION=ap-south-1

# ================== NEXT.JS (baked at build time via GitHub Actions secrets) ==================
# These are here for reference — actual values are passed as --build-arg in CI.
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NODE_OPTIONS=--max-old-space-size=128
NEXT_PUBLIC_API_URL=https://api.nexchool.in
NEXT_PUBLIC_API_URL_DEV=https://api.nexchool.in
NEXT_PUBLIC_GATEWAY_ORIGIN=https://app.nexchool.in
NEXT_PUBLIC_PANEL_URL=https://panel.nexchool.in

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ================== BACKEND PUSH NOTIFICATIONS ==================
FIREBASE_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=
EXPO_ACCESS_TOKEN=
