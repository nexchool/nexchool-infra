# Copy to env/.env.prod (gitignored):
#   cp env/.env.prod.example env/.env.prod
#
# Used by:
#   docker/docker-compose.prod.yml  (build from source + Postgres) — make prod
#   docker/docker-compose.ecr.yml   (ECR images) — ./scripts/start-prod.sh, make deploy-ecr
#
# For docker-compose.prod.yml with bundled Postgres, set DATABASE_URL=...@postgres:5432/...

# ================== COMPOSE / ECR (required for docker-compose.ecr.yml) ==================
ECR_API_URL=123456789012.dkr.ecr.ap-south-1.amazonaws.com/school-erp-prod-api
ECR_ADMIN_WEB_URL=123456789012.dkr.ecr.ap-south-1.amazonaws.com/school-erp-prod-admin-web
ECR_PANEL_URL=123456789012.dkr.ecr.ap-south-1.amazonaws.com/school-erp-prod-panel
API_PORT=5001
HTTP_PORT=80
# TLS (ECR nginx uses nginx/nginx.prod.conf). Host dir must contain fullchain.pem + privkey.pem.
HTTPS_PORT=443
SSL_CERT_DIR=../nginx/ssl
ACME_WEBROOT=../nginx/certbot-webroot

# ================== COMPOSE CONTEXTS (for scripts/deploy.sh prod + build stacks) ==================
SERVER_CONTEXT=../../server
SCHOOL_ADMIN_CONTEXT=../../admin-web
SUPER_ADMIN_CONTEXT=../../panel

# ================== DATABASE ==================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
POSTGRES_DB=school_erp
DATABASE_URL=postgresql://postgres:CHANGEME_STRONG_PASSWORD@postgres:5432/school_erp

# ================== REDIS / CELERY ==================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ================== FLASK API ==================
FLASK_APP=app:create_app
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_EXP_MINUTES=30
DEFAULT_USER_ROLE=Student
DEFAULT_TENANT_SUBDOMAIN=default

PORT=5001
GUNICORN_BIND=0.0.0.0:5001
WEB_CONCURRENCY=1
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

# ================== URLS / CORS / SESSION ==================
BACKEND_URL=https://app.example.com
FRONTEND_URL=schoolerp://
CORS_ORIGINS=https://app.example.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None

# ================== EMAIL ==================
SMTP_SERVER=
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
DEFAULT_SENDER_NAME=
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# ================== AWS / S3 ==================
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
S3_BUCKET_NAME=
S3_ENV_PREFIX=prod
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_PRESIGNED_URL_EXPIRES_SECONDS=86400

# ================== NEXT.JS ==================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NODE_OPTIONS=--max-old-space-size=128
NEXT_PUBLIC_API_URL=https://app.example.com
NEXT_PUBLIC_API_URL_DEV=https://app.example.com
NEXT_PUBLIC_GATEWAY_ORIGIN=https://app.example.com
NEXT_PUBLIC_PANEL_URL=https://app.example.com

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ================== BACKEND PUSH (optional) ==================
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=
EXPO_ACCESS_TOKEN=

# ================== OPTIONAL ==================
PUBLIC_API_URL=
BACKEND_URL_DEV=
FRONTEND_URL_DEV=
LOCAL_IP=
EXPO_PORT=8081
