# Local / non-AWS production-style compose (e.g. docker-compose with env files) — copy to env/.env.prod (gitignored).
#
# AWS EC2 production: application env is NOT maintained here. Terraform is the source of truth:
#   school-erp-infra/aws/terraform/prod.tfvars (gitignored) → user_data writes /home/ec2-user/app/.env
# Key reference: school-erp-infra/aws/terraform/app.env.example

SERVER_CONTEXT=../../server
SCHOOL_ADMIN_CONTEXT=../../admin-web
SUPER_ADMIN_CONTEXT=../../panel

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
POSTGRES_DB=school_erp
DATABASE_URL=postgresql://postgres:CHANGEME_STRONG_PASSWORD@postgres:5432/school_erp

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

API_PORT=5001
PORT=5001
HTTP_PORT=80

FLASK_ENV=production
FLASK_DEBUG=False
JWT_SECRET_KEY=CHANGEME_RANDOM_LONG_STRING
SECRET_KEY=CHANGEME_RANDOM_LONG_STRING

PUBLIC_API_URL=

CORS_ORIGINS=https://your-domain.com
DEFAULT_TENANT_SUBDOMAIN=default
DEFAULT_USER_ROLE=Student
BACKEND_URL=https://api.your-domain.com
FRONTEND_URL=schoolerp://
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None

SMTP_SERVER=
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
DEFAULT_SENDER_NAME=

JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_EXP_MINUTES=30

BACKEND_URL_DEV=
FRONTEND_URL_DEV=
LOCAL_IP=
EXPO_PORT=8081

AWS_REGION=ap-south-1
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
