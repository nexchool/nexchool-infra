# Copy to .env.local (not committed):
#   cp env/.env.local.example env/.env.local
#
# Local Docker — paths relative to school-erp-infra/docker/
#
# When adding variables here, update env/.env.staging.example and env/.env.prod.example
# (and your real .env.staging / .env.prod) so all three stay aligned.

SERVER_CONTEXT=../../server
SCHOOL_ADMIN_CONTEXT=../../admin-web
SUPER_ADMIN_CONTEXT=../../panel

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=school_erp
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/school_erp

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

API_PORT=5001
PORT=5001
HTTP_PORT=80
ADMIN_WEB_HOST_PORT=3000
PANEL_HOST_PORT=3001

FLASK_ENV=development
FLASK_DEBUG=True
# Leave unset in Docker: docker-compose.local.yml sets FLASK_APP=app:create_app.
# If you set FLASK_APP here, use exactly: app:create_app (PYTHONPATH=/app in the API container; app = server/app.py).
JWT_SECRET_KEY=change-me-for-local-only
SECRET_KEY=change-me-for-local-only

PUBLIC_API_URL=

CORS_ORIGINS=http://localhost:80,http://127.0.0.1:80,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
DEFAULT_TENANT_SUBDOMAIN=default
DEFAULT_USER_ROLE=Student

# Optional public URLs (staging/prod use these; local dev often uses BACKEND_URL_DEV below)
BACKEND_URL=
FRONTEND_URL=
SESSION_COOKIE_SECURE=false

# Flask / mail / uploads (optional; was historically server/.env)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
DEFAULT_SENDER_NAME=

JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_EXP_MINUTES=30

BACKEND_URL_DEV=http://localhost:80
FRONTEND_URL_DEV=
LOCAL_IP=
EXPO_PORT=8081

AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
S3_BUCKET_NAME=
S3_ENV_PREFIX=local
# Required for uploads (profile, documents) from the api container — IAM user or similar
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

SESSION_COOKIE_SAMESITE=Lax

# -----------------------------------------------------------------------------
# Push notifications (FCM)
# -----------------------------------------------------------------------------
# API + Celery: FCM HTTP v1 uses a Firebase *service account* (not the Web API key).
#
# Do NOT put raw JSON in this file — Docker Compose .env parsing will break on quotes.
# Instead save the downloaded JSON under the server repo (bind-mounted as /app):
#   <monorepo>/server/secrets/firebase-service-account.json
# Then:
FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json
FCM_PROJECT_ID=

# Admin web (browser): getToken() + firebase-messaging-sw.js — must match the same
# Firebase project. Loaded into the admin-web container via env_file.
# Paste Web app config from Firebase Console → Project settings → Your apps → Web.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Cloud Messaging → Web Push certificates → Web Push key pair (VAPID)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
