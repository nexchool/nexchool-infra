# Reference only — mirrors keys written to /home/ec2-user/app/.env on EC2 (from templates/env.tpl).
# Production values come from Terraform: copy prod.tfvars.example → prod.tfvars (gitignored) and apply.
# Do not commit real .env or prod.tfvars.

# Flask
FLASK_APP=backend.app:create_app
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=CHANGEME
JWT_SECRET_KEY=CHANGEME
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_EXP_MINUTES=30
DEFAULT_USER_ROLE=Student

DATABASE_URL=postgresql://USER:PASS@RDS_HOST:5432/DB_NAME
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

DEFAULT_TENANT_SUBDOMAIN=default
BACKEND_URL=https://your-public-origin
FRONTEND_URL=schoolerp://
CORS_ORIGINS=https://your-public-origin
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

SMTP_SERVER=
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
DEFAULT_SENDER_NAME=
MAIL_USE_TLS=true

AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket

PORT=5001
GUNICORN_BIND=0.0.0.0:5001
WEB_CONCURRENCY=1
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

# Next.js (admin-web + panel)
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NODE_OPTIONS=--max-old-space-size=128
NEXT_PUBLIC_API_URL=https://your-public-origin
NEXT_PUBLIC_API_URL_DEV=https://your-public-origin
NEXT_PUBLIC_GATEWAY_ORIGIN=
